<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="ADQA v$(env.VERSION)"
           Manufacturer="Mohammad Talaat"
           Version="$(env.VERSION)"
           UpgradeCode="d2b0e7f9-7aa9-446b-8f40-d4d9370040d2">

    <MajorUpgrade DowngradeErrorMessage="A newer version of ADQA is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <ComponentGroupRef Id="AppComponents" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Mohammad-Talaat7/autonomous-data-quality-agent" />
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="./distribution/win/LICENSE.rtf" />

  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ADQA v$(env.VERSION)" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="InstallProgramMenuFolder" Name="ADQA" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppComponents">

      <!-- PATH environment variable component -->
      <Component Id="UpdatePathComponent" Directory="INSTALLFOLDER">
        <RegistryValue Root="HKLM"
                       Key="Software\ADQA"
                       Name="PathConfigured"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
					   
        <Environment Id="UpdatePath"
                     Name="PATH"
                     Value="[INSTALLFOLDER]\bin"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
      </Component>

      <!-- Start Menu shortcuts component -->
      <Component Id="StartMenuShortcuts" Directory="InstallProgramMenuFolder">
		<Shortcut Id="AppStartMenuShortcut1"
				  Name="adqa-cli"
				  Description="Autonomous Data Quality Agent CLI"
				  Target="[SystemFolder]cmd.exe"
				  Arguments='/k "[INSTALLFOLDER]\bin\adqa-cli.exe"'
				  WorkingDirectory="INSTALLFOLDER" />
		
		<Shortcut Id="AppStartMenuShortcut2"
                  Name="adqa-tui"
                  Description="Autonomous Data Quality Agent"
                  Target="[INSTALLFOLDER]\bin\adqa-tui.exe"
                  WorkingDirectory="INSTALLFOLDER" />
				  
        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall ADQA"
                  Description="Uninstalls ADQA"
                  Target="[SystemFolder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
				  
        <!-- Registry sentinel as KeyPath for this component -->
        <RegistryValue Root="HKCU"
                       Key="Software\ADQA"
                       Name="StartMenuInstalled"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
					   
        <!-- Removes the Start Menu folder on uninstall -->
        <RemoveFolder Id="RemoveStartMenuFolder"
                      Directory="InstallProgramMenuFolder"
                      On="uninstall" />
      </Component>

      <Files Include=".\$(env.BINARY_NAME)\**" Directory="INSTALLFOLDER" />

    </ComponentGroup>
  </Fragment>

</Wix>